---
import SchemaOrg from "../components/SchemaOrg.astro";
interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = "写真1枚でAIが診断・解決策を提案。壁キズ・カビ・タイヤなど無料で使えるAI診断ツール集",
  ogImage = "/og/default.png",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const adsenseId = import.meta.env.PUBLIC_ADSENSE_CLIENT_ID;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- OGP -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site).toString()} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="撮偵" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="author" content="撮偵 — AIホームケア診断" />

    <!-- Structured Data -->
    {!Astro.slots.has("head") && <SchemaOrg type="website" />}
    <slot name="head" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=M+PLUS+Rounded+1c:wght@700;800;900&family=Noto+Sans+JP:wght@400;500;700&display=swap"
      rel="stylesheet"
    />

    <meta name="google-adsense-account" content="ca-pub-6501521264241403" />

    {adsenseId && (
      <script
        async
        src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${adsenseId}`}
        crossorigin="anonymous"
      />
    )}

    <!-- Google Analytics 4 -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-PRR2SJV8N0"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){window.dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-PRR2SJV8N0');
    </script>
  </head>
  <body>
    <header class="site-header">
      <div class="container hstack">
        <a href="/" class="logo">
          <span class="logo-icon">📷</span>
          撮<span class="logo-accent">偵</span>
        </a>
        <nav class="main-nav">
          <a href="/" class="nav-link">診断ツール</a>
          <a href="/guide/" class="nav-link">ガイド</a>
        </nav>
      </div>
    </header>

    <main class="main-content">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container">
        <p class="footer-logo">📷 撮<span class="logo-accent">偵</span></p>
        <p class="footer-tagline">写真1枚で、AIが解決策を診断する無料ツール集</p>
        <p class="affiliate-notice">
          本サイトはAmazonアソシエイト・楽天アフィリエイト等のアフィリエイトプログラムに参加しています。
          記事内のリンクから商品を購入いただいた場合、報酬が発生することがあります。
        </p>
        <nav class="footer-nav">
          <a href="/privacy/">プライバシーポリシー</a>
          <a href="/terms/">利用規約</a>
          <a href="/contact/">お問い合わせ</a>
          <a href="/about/">運営者情報</a>
        </nav>
      </div>
    </footer>
  </body>
</html>

<style is:global>
/* ============================================
   CSS CUSTOM PROPERTIES
   ============================================ */
:root {
  /* Backgrounds */
  --bg:        #FFFFFF;
  --bg-alt:    #F8FAFC;
  --bg-warm:   #FFFBF7;
  --surface:   #FFFFFF;
  --surface-2: #F4F7FB;

  /* Borders */
  --border:     #E8ECF2;
  --border-mid: #D2D9E6;

  /* Text */
  --text:       #1A1D24;
  --text-muted: #64748B;
  --text-dim:   #9CA3AF;

  /* Primary — coral orange */
  --primary:       #FF5E2A;
  --primary-hover: #E84E1A;
  --primary-light: #FFF2EC;
  --primary-mid:   #FFD8C8;

  /* Green */
  --green:       #16A34A;
  --green-vivid: #22C55E;
  --green-light: #DCFCE7;

  /* Yellow */
  --yellow:      #D97706;
  --yellow-vivid:#F59E0B;
  --yellow-light:#FEF3C7;

  /* Red */
  --red:         #DC2626;
  --red-light:   #FEE2E2;

  /* Blue */
  --blue:        #2563EB;
  --blue-light:  #EFF6FF;

  /* Amazon/Rakuten */
  --amazon:      #FF9900;
  --rakuten:     #BF0000;

  /* Typography */
  --font-display: 'M PLUS Rounded 1c', 'Hiragino Maru Gothic ProN', 'Rounded Mplus 1c', sans-serif;
  --font-body:    'Noto Sans JP', 'Hiragino Sans', 'Yu Gothic', sans-serif;

  /* Geometry */
  --radius-sm: 8px;
  --radius:    14px;
  --radius-lg: 20px;
  --radius-xl: 28px;

  /* Shadows */
  --shadow-xs: 0 1px 3px rgba(0,0,0,0.06), 0 1px 2px rgba(0,0,0,0.04);
  --shadow-sm: 0 2px 8px rgba(0,0,0,0.07), 0 1px 3px rgba(0,0,0,0.05);
  --shadow:    0 4px 20px rgba(0,0,0,0.08), 0 2px 6px rgba(0,0,0,0.05);
  --shadow-lg: 0 12px 40px rgba(0,0,0,0.12), 0 4px 12px rgba(0,0,0,0.06);
  --shadow-primary: 0 6px 24px rgba(255,94,42,0.28);

  /* Layout */
  --container: 960px;
  --px: clamp(1rem, 4vw, 1.75rem);
}

/* ============================================
   RESET & BASE
   ============================================ */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

html {
  font-size: 16px;
  scroll-behavior: smooth;
  -webkit-text-size-adjust: 100%;
}

body {
  font-family: var(--font-body);
  background: var(--bg);
  color: var(--text);
  line-height: 1.7;
  min-height: 100dvh;
  display: flex;
  flex-direction: column;
  -webkit-font-smoothing: antialiased;
}

img { max-width: 100%; height: auto; display: block; }
a { color: inherit; text-decoration: none; }
button { cursor: pointer; font-family: inherit; }

/* ============================================
   LAYOUT
   ============================================ */
.container {
  max-width: var(--container);
  margin-inline: auto;
  padding-inline: var(--px);
}

.hstack { display: flex; align-items: center; }
.main-content { flex: 1; }

/* ============================================
   HEADER
   ============================================ */
.site-header {
  position: sticky;
  top: 0;
  z-index: 100;
  background: rgba(255,255,255,0.92);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border-bottom: 1px solid var(--border);
  box-shadow: var(--shadow-xs);
}

.site-header .hstack {
  height: 60px;
  justify-content: space-between;
}

.logo {
  display: flex;
  align-items: center;
  gap: 0.35rem;
  font-family: var(--font-display);
  font-weight: 900;
  font-size: 1.4rem;
  color: var(--text);
  transition: opacity 0.18s;
}
.logo:hover { opacity: 0.75; }
.logo-icon { font-size: 1.25rem; line-height: 1; }
.logo-accent { color: var(--primary); }

.main-nav { display: flex; gap: 0.25rem; }

.nav-link {
  padding: 0.4rem 0.875rem;
  border-radius: var(--radius-sm);
  font-size: 0.875rem;
  font-weight: 500;
  color: var(--text-muted);
  transition: color 0.18s, background 0.18s;
}
.nav-link:hover {
  color: var(--text);
  background: var(--surface-2);
}

/* ============================================
   FOOTER
   ============================================ */
.site-footer {
  background: var(--bg-alt);
  border-top: 1px solid var(--border);
  padding: 2.5rem 0;
  margin-top: 4rem;
  text-align: center;
}

.footer-logo {
  font-family: var(--font-display);
  font-weight: 900;
  font-size: 1.5rem;
  margin-bottom: 0.375rem;
  color: var(--text);
}

.footer-tagline {
  font-size: 0.85rem;
  color: var(--text-muted);
  margin-bottom: 1.25rem;
}

.affiliate-notice {
  font-size: 0.72rem;
  color: var(--text-dim);
  max-width: 460px;
  margin: 0 auto 1.25rem;
  line-height: 1.65;
}

.footer-nav {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 0.25rem 1rem;
}
.footer-nav a {
  font-size: 0.78rem;
  color: var(--text-muted);
  transition: color 0.18s;
}
.footer-nav a:hover { color: var(--text); }

/* ============================================
   BUTTONS
   ============================================ */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 0.5rem;
  padding: 0.75rem 1.5rem;
  border-radius: var(--radius);
  font-family: var(--font-body);
  font-weight: 700;
  font-size: 0.9375rem;
  border: none;
  transition: all 0.18s;
  cursor: pointer;
  white-space: nowrap;
  line-height: 1;
}

.btn-primary {
  background: var(--primary);
  color: #FFFFFF;
  box-shadow: var(--shadow-primary);
}
.btn-primary:hover:not(:disabled) {
  background: var(--primary-hover);
  transform: translateY(-1px);
  box-shadow: 0 8px 28px rgba(255,94,42,0.35);
}

.btn-outline {
  background: transparent;
  color: var(--primary);
  border: 2px solid var(--primary);
}
.btn-outline:hover:not(:disabled) {
  background: var(--primary-light);
  transform: translateY(-1px);
}

.btn-ghost {
  background: var(--surface-2);
  color: var(--text-muted);
  border: 1.5px solid var(--border);
}
.btn-ghost:hover:not(:disabled) {
  color: var(--text);
  border-color: var(--border-mid);
  background: var(--bg-alt);
}

.btn:disabled {
  opacity: 0.5;
  cursor: not-allowed;
  transform: none !important;
  box-shadow: none !important;
}

.btn-lg {
  padding: 1rem 2rem;
  font-size: 1.0625rem;
  border-radius: var(--radius-lg);
}

/* ============================================
   HERO
   ============================================ */
.hero {
  padding: clamp(3rem, 8vw, 6rem) var(--px) clamp(2.5rem, 6vw, 4.5rem);
  text-align: center;
  background: linear-gradient(160deg, #FFF5F1 0%, #FFFFFF 55%);
  position: relative;
  overflow: hidden;
}

.hero::before {
  content: '';
  position: absolute;
  top: -80px;
  right: -100px;
  width: 400px;
  height: 400px;
  background: radial-gradient(circle, rgba(255,94,42,0.08) 0%, transparent 65%);
  pointer-events: none;
}

.hero::after {
  content: '';
  position: absolute;
  bottom: -60px;
  left: -80px;
  width: 300px;
  height: 300px;
  background: radial-gradient(circle, rgba(34,197,94,0.07) 0%, transparent 65%);
  pointer-events: none;
}

.hero > * { position: relative; z-index: 1; }

.hero-eyebrow {
  display: inline-flex;
  align-items: center;
  gap: 0.4rem;
  background: var(--primary-light);
  border: 1.5px solid var(--primary-mid);
  border-radius: 999px;
  padding: 0.35rem 1.1rem;
  font-size: 0.8rem;
  font-weight: 700;
  color: var(--primary);
  margin-bottom: 1.5rem;
  letter-spacing: 0.04em;
}

.hero-title {
  font-family: var(--font-display);
  font-weight: 900;
  font-size: clamp(2.25rem, 6.5vw, 4rem);
  line-height: 1.15;
  margin-bottom: 1rem;
  letter-spacing: -0.01em;
  color: var(--text);
}

.hero-title em {
  font-style: normal;
  color: var(--primary);
  background: linear-gradient(135deg, var(--primary), #FF8C5A);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.hero-desc {
  font-size: clamp(0.9375rem, 2.5vw, 1.125rem);
  color: var(--text-muted);
  max-width: 460px;
  margin: 0 auto 2rem;
  line-height: 1.75;
}

.hero-badges {
  display: flex;
  gap: 0.625rem;
  justify-content: center;
  flex-wrap: wrap;
  margin-top: 0.75rem;
}

.pill-badge {
  display: inline-flex;
  align-items: center;
  gap: 0.3rem;
  padding: 0.3rem 0.875rem;
  border-radius: 999px;
  font-size: 0.8rem;
  font-weight: 700;
}

.pill-green {
  background: var(--green-light);
  color: var(--green);
  border: 1px solid rgba(34,197,94,0.25);
}

.pill-blue {
  background: var(--blue-light);
  color: var(--blue);
  border: 1px solid rgba(37,99,235,0.18);
}

.pill-orange {
  background: var(--primary-light);
  color: var(--primary);
  border: 1.5px solid var(--primary-mid);
}

/* ============================================
   SECTION LABELS
   ============================================ */
.section-eyebrow {
  font-size: 0.72rem;
  font-weight: 700;
  color: var(--text-dim);
  text-transform: uppercase;
  letter-spacing: 0.14em;
  margin-bottom: 1.125rem;
}

/* ============================================
   APP CARDS
   ============================================ */
.apps-section {
  padding: clamp(2rem, 5vw, 3.5rem) var(--px);
}

.apps-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(min(100%, 280px), 1fr));
  gap: 1rem;
}

.app-card {
  background: var(--surface);
  border: 1.5px solid var(--border);
  border-radius: var(--radius-lg);
  padding: 1.5rem;
  display: flex;
  flex-direction: column;
  gap: 0.875rem;
  text-decoration: none;
  transition: all 0.22s;
  position: relative;
  overflow: hidden;
}

.app-card:hover {
  border-color: var(--primary);
  transform: translateY(-4px);
  box-shadow: var(--shadow-lg), 0 0 0 3px var(--primary-light);
}

.app-card-icon-wrap {
  width: 52px;
  height: 52px;
  border-radius: var(--radius);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.75rem;
  flex-shrink: 0;
}

.icon-bg-orange { background: var(--primary-light); }
.icon-bg-green  { background: var(--green-light); }
.icon-bg-blue   { background: var(--blue-light); }
.icon-bg-yellow { background: var(--yellow-light); }

.app-card-name {
  font-family: var(--font-display);
  font-weight: 800;
  font-size: 1.1rem;
  color: var(--text);
  margin-bottom: 0.25rem;
}

.app-card-desc {
  font-size: 0.85rem;
  color: var(--text-muted);
  line-height: 1.65;
  flex: 1;
}

.app-card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 0.25rem;
  padding-top: 0.875rem;
  border-top: 1px solid var(--border);
}

.app-card-cta-text {
  font-size: 0.875rem;
  font-weight: 700;
  color: var(--primary);
}

.app-card-arrow {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  background: var(--primary-light);
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 0.9rem;
  color: var(--primary);
  transition: all 0.2s;
  flex-shrink: 0;
}

.app-card:hover .app-card-arrow {
  background: var(--primary);
  color: #FFFFFF;
}

/* ============================================
   HOW IT WORKS (steps)
   ============================================ */
.steps-section {
  padding: 0 var(--px) clamp(2.5rem, 6vw, 4.5rem);
}

.steps-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(min(100%, 200px), 1fr));
  gap: 1rem;
}

.step-card {
  background: var(--bg-alt);
  border: 1.5px solid var(--border);
  border-radius: var(--radius-lg);
  padding: 1.375rem;
}

.step-num {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 28px;
  height: 28px;
  border-radius: 50%;
  background: var(--primary);
  color: white;
  font-size: 0.8rem;
  font-weight: 900;
  font-family: var(--font-display);
  margin-bottom: 0.875rem;
}

.step-icon { font-size: 1.875rem; margin-bottom: 0.625rem; }

.step-title {
  font-family: var(--font-display);
  font-weight: 800;
  font-size: 1rem;
  color: var(--text);
  margin-bottom: 0.3rem;
}

.step-desc {
  font-size: 0.8125rem;
  color: var(--text-muted);
  line-height: 1.65;
}

/* ============================================
   GUIDE TEASER
   ============================================ */
.guide-teaser {
  background: linear-gradient(135deg, #F0FDF4, #F8FAFC);
  border-top: 1.5px solid var(--green-light);
  border-bottom: 1.5px solid var(--green-light);
  padding: clamp(2.5rem, 6vw, 4rem) var(--px);
  text-align: center;
}

.guide-teaser-title {
  font-family: var(--font-display);
  font-weight: 800;
  font-size: clamp(1.25rem, 3.5vw, 1.75rem);
  color: var(--text);
  margin-bottom: 0.625rem;
}

.guide-teaser-desc {
  font-size: 0.9rem;
  color: var(--text-muted);
  margin: 0 auto 1.75rem;
  max-width: 420px;
  line-height: 1.7;
}

/* ============================================
   GUIDE PAGE
   ============================================ */
.guide-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(min(100%, 260px), 1fr));
  gap: 1rem;
}

.guide-card {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
  background: var(--surface);
  border: 1.5px solid var(--border);
  border-radius: var(--radius-lg);
  padding: 1.25rem 1.5rem;
  text-decoration: none;
  transition: all 0.2s;
}
.guide-card:hover {
  border-color: var(--primary);
  transform: translateY(-2px);
  box-shadow: var(--shadow);
}
.guide-card-title {
  font-weight: 700;
  font-size: 0.9375rem;
  color: var(--text);
  line-height: 1.5;
  flex: 1;
}
.guide-card-desc {
  font-size: 0.8125rem;
  color: var(--text-muted);
  line-height: 1.55;
}
.guide-card-date {
  font-size: 0.72rem;
  color: var(--text-dim);
  font-variant-numeric: tabular-nums;
}

/* ============================================
   TOOL PAGE
   ============================================ */
.tool-page {
  padding: clamp(2rem, 5vw, 3.5rem) var(--px) clamp(3rem, 7vw, 5rem);
  max-width: 640px;
  margin-inline: auto;
}

.tool-header { margin-bottom: 1.75rem; }

.tool-icon {
  font-size: 2.5rem;
  display: block;
  margin-bottom: 0.75rem;
}

.tool-title {
  font-family: var(--font-display);
  font-weight: 900;
  font-size: clamp(1.5rem, 5vw, 2rem);
  margin-bottom: 0.5rem;
  line-height: 1.2;
  color: var(--text);
}

.tool-desc {
  font-size: 0.9375rem;
  color: var(--text-muted);
  line-height: 1.65;
}

.how-to {
  display: flex;
  align-items: flex-start;
  gap: 0.75rem;
  background: var(--primary-light);
  border-left: 3px solid var(--primary);
  border-radius: 0 var(--radius) var(--radius) 0;
  padding: 0.875rem 1.125rem;
  margin-bottom: 1.5rem;
  font-size: 0.84375rem;
  color: var(--text-muted);
  line-height: 1.65;
}
.how-to-icon { font-size: 1.1rem; flex-shrink: 0; margin-top: 0.05em; }

/* ============================================
   UPLOAD AREA
   ============================================ */
.upload-area {
  border: 2.5px dashed var(--border-mid);
  border-radius: var(--radius-lg);
  padding: 2.25rem 1.5rem;
  text-align: center;
  cursor: pointer;
  transition: all 0.2s;
  background: var(--bg-alt);
  min-height: 180px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.upload-area:hover,
.upload-area.drag-over {
  border-color: var(--primary);
  background: var(--primary-light);
}

.upload-icon { font-size: 3rem; display: block; margin-bottom: 0.75rem; line-height: 1; }

.upload-title {
  font-family: var(--font-display);
  font-weight: 800;
  font-size: 1rem;
  color: var(--text);
  margin-bottom: 0.3rem;
}

.upload-hint { font-size: 0.8125rem; color: var(--text-muted); }

/* ============================================
   PREVIEW & SCANNING
   ============================================ */
.preview-wrap {
  position: relative;
  border-radius: var(--radius-lg);
  overflow: hidden;
  background: var(--surface-2);
  border: 1.5px solid var(--border);
}

.preview-img {
  width: 100%;
  max-height: 280px;
  object-fit: contain;
  display: block;
}

.scan-overlay {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  gap: 0.875rem;
  background: rgba(255,255,255,0.82);
  backdrop-filter: blur(2px);
}

.scan-bar {
  position: absolute;
  inset-inline: 0;
  height: 3px;
  background: linear-gradient(90deg, transparent, var(--primary), transparent);
  box-shadow: 0 0 12px rgba(255,94,42,0.5);
  animation: scanDown 1.8s ease-in-out infinite;
}

@keyframes scanDown {
  0%   { top: 0%;   opacity: 1; }
  85%  { opacity: 1; }
  100% { top: 100%; opacity: 0; }
}

.scan-label {
  position: relative;
  font-family: var(--font-display);
  font-weight: 800;
  font-size: 1rem;
