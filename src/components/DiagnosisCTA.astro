---
interface Props {
  diagnosisType: "diy-repair" | "kabi-diagnosis";
  variant?: "top" | "bottom";
}

const { diagnosisType, variant = "bottom" } = Astro.props;

const config = {
  "diy-repair": {
    href: "/diy-repair/",
    icon: "修理",
    label: "AI修理診断ツール",
    description: "画像を1枚送るだけで、DIYでの対処方針と必要な道具を整理できます。",
    cta: "無料で修理診断する",
    gaEvent: "cta_click_diy_repair",
  },
  "kabi-diagnosis": {
    href: "/kabi-diagnosis/",
    icon: "カビ",
    label: "AIカビ診断ツール",
    description: "画像からカビの状態と対処の方向性をすばやく整理できます。",
    cta: "無料でカビ診断する",
    gaEvent: "cta_click_kabi_diagnosis",
  },
} as const;

const c = config[diagnosisType];
---

<div class={`diagnosis-cta diagnosis-cta--${variant}`} data-ga-event={c.gaEvent}>
  <div class="diagnosis-cta__inner">
    <span class="diagnosis-cta__icon">{c.icon}</span>
    <div class="diagnosis-cta__body">
      <p class="diagnosis-cta__label">{c.label}</p>
      <p class="diagnosis-cta__desc">{c.description}</p>
    </div>
    <a href={c.href} class="diagnosis-cta__btn">
      {c.cta}
    </a>
  </div>
</div>

<script is:inline>
  document.querySelectorAll(".diagnosis-cta").forEach((el) => {
    const event = el.dataset.gaEvent;
    if (!event) return;
    el.querySelector("a")?.addEventListener("click", () => {
      if (typeof gtag !== "undefined") {
        gtag("event", event, { event_category: "cta" });
      }
    });
  });
</script>

<style>
.diagnosis-cta {
  margin: 1.75rem 0;
  border-radius: var(--radius);
  overflow: hidden;
}

.diagnosis-cta--top {
  background: var(--primary-light);
  border: 1.5px solid var(--primary-mid);
}

.diagnosis-cta--top .diagnosis-cta__inner {
  display: flex;
  align-items: center;
  gap: 1rem;
  padding: 1rem 1.25rem;
  flex-wrap: wrap;
}

.diagnosis-cta--top .diagnosis-cta__icon {
  font-size: 1.1rem;
  font-weight: 700;
  flex-shrink: 0;
}

.diagnosis-cta--top .diagnosis-cta__body {
  flex: 1;
  min-width: 0;
}

.diagnosis-cta--top .diagnosis-cta__label {
  font-size: 0.8125rem;
  font-weight: 700;
  color: var(--primary);
  margin-bottom: 0.125rem;
}

.diagnosis-cta--top .diagnosis-cta__desc {
  font-size: 0.8125rem;
  color: var(--text-muted);
  line-height: 1.5;
}

.diagnosis-cta--top .diagnosis-cta__btn {
  display: inline-block;
  background: var(--primary);
  color: #fff;
  font-size: 0.8125rem;
  font-weight: 700;
  padding: 0.5rem 1.125rem;
  border-radius: var(--radius-sm);
  white-space: nowrap;
  transition: background 0.15s;
  flex-shrink: 0;
}

.diagnosis-cta--top .diagnosis-cta__btn:hover {
  background: var(--primary-hover);
}

.diagnosis-cta--bottom {
  background: linear-gradient(135deg, var(--primary) 0%, #ff7c4d 100%);
  box-shadow: var(--shadow-primary);
}

.diagnosis-cta--bottom .diagnosis-cta__inner {
  display: flex;
  align-items: center;
  gap: 1.25rem;
  padding: 1.375rem 1.5rem;
  flex-wrap: wrap;
}

.diagnosis-cta--bottom .diagnosis-cta__icon {
  font-size: 1.35rem;
  font-weight: 700;
  flex-shrink: 0;
}

.diagnosis-cta--bottom .diagnosis-cta__body {
  flex: 1;
  min-width: 0;
}

.diagnosis-cta--bottom .diagnosis-cta__label {
  font-size: 0.9375rem;
  font-weight: 700;
  color: rgba(255,255,255,0.85);
  margin-bottom: 0.25rem;
}

.diagnosis-cta--bottom .diagnosis-cta__desc {
  font-size: 0.875rem;
  color: rgba(255,255,255,0.9);
  line-height: 1.5;
}

.diagnosis-cta--bottom .diagnosis-cta__btn {
  display: inline-block;
  background: #fff;
  color: var(--primary);
  font-size: 0.9375rem;
  font-weight: 700;
  padding: 0.625rem 1.375rem;
  border-radius: var(--radius-sm);
  white-space: nowrap;
  transition: opacity 0.15s;
  flex-shrink: 0;
  box-shadow: var(--shadow-xs);
}

.diagnosis-cta--bottom .diagnosis-cta__btn:hover {
  opacity: 0.92;
}

@media (max-width: 540px) {
  .diagnosis-cta--top .diagnosis-cta__inner,
  .diagnosis-cta--bottom .diagnosis-cta__inner {
    flex-direction: column;
    align-items: flex-start;
    gap: 0.75rem;
  }

  .diagnosis-cta--bottom .diagnosis-cta__btn,
  .diagnosis-cta--top .diagnosis-cta__btn {
    width: 100%;
    text-align: center;
  }
}
</style>
