---
import Base from "../../../layouts/Base.astro";
import AdUnit from "../../../components/AdUnit.astro";
import DiagnosisCTA from "../../../components/DiagnosisCTA.astro";
import { getConfig } from "../../../configs/index";
import { getEntry } from "astro:content";

const { appId } = Astro.params;
const config = getConfig(appId!);
if (!config) return Astro.redirect("/404");

const RELATED_ARTICLES: Record<string, string[]> = {
  "kabi-diagnosis": ["black-mold-removal", "mold-prevention-spray", "wallpaper-repair-seal"],
  "diy-repair": ["floor-repair-paste", "wallpaper-repair", "flooring-scratch"],
};

const relatedSlugs = RELATED_ARTICLES[appId!] ?? [];
const relatedEntries = (
  await Promise.all(relatedSlugs.map((slug) => Promise.resolve(getEntry("guide", slug as any)).then((e) => e ?? null).catch(() => null)))
).filter(Boolean);
---

<Base title={`診断結果 | ${config.name}`}>
  <div class="article-page">
    <h1 class="page-title">診断結果</h1>
    <p class="page-desc">
      このページは共有用の診断結果ページです。診断した結果を確認したい場合は、元の診断ツール画面に戻ってください。
    </p>

    <AdUnit slot={import.meta.env.PUBLIC_ADSENSE_SLOT_TOP} />

    {relatedEntries.length > 0 && (
      <section class="related-section">
        <h2 class="related-title">こちらの記事もどうぞ</h2>
        <div class="related-grid">
          {relatedEntries.map((entry) => entry && (
            <a href={`/guide/${entry.id}/`} class="related-card">
              <div class="related-card-title">{entry.data.title}</div>
              <div class="related-card-desc">{entry.data.description}</div>
            </a>
          ))}
        </div>
      </section>
    )}

    <DiagnosisCTA diagnosisType={appId as "kabi-diagnosis" | "diy-repair"} variant="bottom" />

    <p class="article-back"><a href={`/${appId}/`}>診断ツールに戻る</a></p>
  </div>
</Base>

<style>
.related-section {
  margin: 2rem 0;
}
.related-title {
  font-family: var(--font-display);
  font-size: 1.1rem;
  font-weight: 800;
  margin-bottom: 1rem;
  color: var(--text);
}
.related-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: 0.75rem;
}
.related-card {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
  padding: 1rem;
  border-radius: var(--radius);
  border: 1.5px solid var(--border);
  background: var(--surface);
  box-shadow: var(--shadow-xs);
  transition: transform 0.18s, box-shadow 0.18s;
}
.related-card:hover {
  transform: translateY(-2px);
  box-shadow: var(--shadow);
}
.related-card-title {
  font-size: 0.9375rem;
  font-weight: 700;
  color: var(--text);
}
.related-card-desc {
  font-size: 0.8125rem;
  color: var(--text-muted);
  line-height: 1.5;
}
</style>
