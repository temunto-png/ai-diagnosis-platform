---
export const prerender = true;

import Base from "../../layouts/Base.astro";
import DiagnosisApp from "../../components/DiagnosisApp";
import { getConfig, listApps } from "../../configs/index";

export async function getStaticPaths() {
  return listApps().map(({ id }) => ({ params: { appId: id } }));
}

const { appId } = Astro.params;
const config = getConfig(appId!);
if (!config) return Astro.redirect("/404");

const appMeta: Record<string, { icon: string }> = {
  "diy-repair": { icon: "🛠️" },
  "kabi-diagnosis": { icon: "🦠" },
};
const meta = appMeta[appId!] ?? { icon: "📷" };
---

<Base title={config.seo.title} description={config.seo.description} ogImage={`/og/${appId}.png`}>
  <div class="tool-page">
    <div class="tool-header">
      <span class="tool-icon">{meta.icon}</span>
      <h1 class="tool-title">{config.name}</h1>
      <p class="tool-desc">{config.description}</p>
    </div>

    <div class="how-to">
      <span class="how-to-icon">💡</span>
      <span>写真をアップロードすると、AI が状態を解析し、原因の候補や対策のヒントをわかりやすく返します。</span>
    </div>

    <DiagnosisApp client:load appId={appId!} />
  </div>
</Base>
