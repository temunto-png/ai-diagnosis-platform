---
export const prerender = true;

import Base from "../layouts/Base.astro";
import AdUnit from "../components/AdUnit.astro";
import { listApps } from "../configs/index";

const apps = listApps();

const appMeta: Record<string, { icon: string; iconBg: string; tagline: string }> = {
  "diy-repair": {
    icon: "修理",
    iconBg: "icon-bg-orange",
    tagline: "壁や床のキズをチェック",
  },
  "kabi-diagnosis": {
    icon: "カビ",
    iconBg: "icon-bg-green",
    tagline: "住まいのカビ状態を整理",
  },
};
---

<Base
  title="さつてい | 画像1枚で住まいの状態をAI診断"
  description="画像を送るだけで、修理・キズ・カビなどの状態をAIが整理する住まい向け診断ツールです。"
>
  <section class="hero">
    <div class="hero-eyebrow">AI画像診断ツール</div>
    <h1 class="hero-title">
      画像<em>1枚</em>で<br />住まいの状態をAI診断
    </h1>
    <p class="hero-desc">
      壁のキズ、床のへこみ、カビなど。<br />
      気になる場所を撮るだけで、診断結果と次の一手を整理できます。
    </p>
    <div class="hero-badges">
      <span class="pill-badge pill-orange">無料で使える</span>
      <span class="pill-badge pill-orange">数秒で診断開始</span>
    </div>
  </section>

  <section class="apps-section">
    <div class="container">
      <p class="section-eyebrow">診断ツール一覧</p>
      <div class="apps-grid">
        {apps.map((app) => {
          const meta = appMeta[app.id] ?? { icon: "診断", iconBg: "icon-bg-blue", tagline: "" };
          return (
            <a href={`/${app.id}/`} class="app-card">
              <div class={`app-card-icon-wrap ${meta.iconBg}`}>{meta.icon}</div>
              <div>
                <div class="app-card-name">{app.name}</div>
                <div class="app-card-desc">{app.description}</div>
              </div>
              <div class="app-card-footer">
                <span class="app-card-cta-text">無料で診断する</span>
                <span class="app-card-arrow">→</span>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <section class="steps-section">
    <div class="container">
      <p class="section-eyebrow">使い方 3ステップ</p>
      <div class="steps-grid">
        {[
          { step: "1", icon: "撮影", title: "画像を用意", desc: "スマホで気になる場所を撮影するだけです。" },
          { step: "2", icon: "解析", title: "AIが診断", desc: "画像をもとに状態や深刻度を整理します。" },
          { step: "3", icon: "対策", title: "次の一手を確認", desc: "対処の方向性や参考アイテムを確認できます。" },
        ].map(({ step, icon, title, desc }) => (
          <div class="step-card">
            <div class="step-num">{step}</div>
            <div class="step-icon">{icon}</div>
            <div class="step-title">{title}</div>
            <div class="step-desc">{desc}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="guide-teaser">
    <div class="container">
      <p class="section-eyebrow" style="color: var(--green);">使い方ガイド</p>
      <h2 class="guide-teaser-title">DIY修理やカビ対策の詳しい記事も公開中</h2>
      <p class="guide-teaser-desc">
        診断だけでなく、対処方法や注意点をまとめたガイド記事も読めます。
      </p>
      <a href="/guide/" class="btn btn-outline" style="color:var(--green);border-color:var(--green);">
        ガイドを読む →
      </a>
    </div>
  </section>

  <div class="container">
    <AdUnit slot={import.meta.env.PUBLIC_ADSENSE_SLOT_TOP} />
  </div>
</Base>

<style>
.hero {
  max-width: 960px;
  margin: 0 auto;
  padding: clamp(3rem, 7vw, 5rem) var(--px) clamp(2.5rem, 6vw, 4rem);
}
.hero-eyebrow,
.section-eyebrow {
  font-size: 0.78rem;
  font-weight: 700;
  letter-spacing: 0.08em;
  color: var(--primary);
  margin-bottom: 0.75rem;
}
.hero-title {
  font-family: var(--font-display);
  font-size: clamp(2.1rem, 7vw, 4.2rem);
  line-height: 1.08;
  margin-bottom: 1rem;
}
.hero-title em {
  color: var(--primary);
  font-style: normal;
}
.hero-desc {
  color: var(--text-muted);
  font-size: 1rem;
  max-width: 42rem;
}
.hero-badges {
  display: flex;
  gap: 0.75rem;
  flex-wrap: wrap;
  margin-top: 1.25rem;
}
.pill-badge {
  display: inline-flex;
  align-items: center;
  padding: 0.45rem 0.9rem;
  border-radius: 999px;
  font-size: 0.82rem;
  font-weight: 700;
}
.pill-orange {
  background: var(--primary-light);
  color: var(--primary);
  border: 1px solid var(--primary-mid);
}
.apps-section,
.steps-section,
.guide-teaser {
  padding: 0 var(--px) clamp(3rem, 6vw, 4.5rem);
}
.apps-grid,
.steps-grid {
  display: grid;
  gap: 1rem;
}
.apps-grid {
  grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
}
.app-card {
  display: flex;
  flex-direction: column;
  gap: 1rem;
  padding: 1.25rem;
  border: 1.5px solid var(--border);
  border-radius: var(--radius-lg);
  background: var(--surface);
  box-shadow: var(--shadow-xs);
  transition: transform 0.18s, box-shadow 0.18s, border-color 0.18s;
}
.app-card:hover {
  transform: translateY(-2px);
  border-color: var(--primary-mid);
  box-shadow: var(--shadow);
}
.app-card-icon-wrap {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 3.5rem;
  height: 3.5rem;
  border-radius: 1rem;
  font-weight: 800;
}
.icon-bg-orange {
  background: #fff2ec;
  color: #d96437;
}
.icon-bg-green {
  background: #ecfdf3;
  color: #15803d;
}
.icon-bg-blue {
  background: #eff6ff;
  color: #2563eb;
}
.app-card-name {
  font-family: var(--font-display);
  font-size: 1.1rem;
  font-weight: 800;
  margin-bottom: 0.35rem;
}
.app-card-desc {
  color: var(--text-muted);
  font-size: 0.92rem;
}
.app-card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  color: var(--primary);
  font-weight: 700;
}
.steps-grid {
  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
}
.step-card {
  border: 1.5px solid var(--border);
  border-radius: var(--radius-lg);
  padding: 1.25rem;
  background: linear-gradient(180deg, #fff, #fbfcfe);
}
.step-num {
  font-size: 0.8rem;
  font-weight: 700;
  color: var(--primary);
  margin-bottom: 0.5rem;
}
.step-icon {
  font-size: 1.1rem;
  font-weight: 800;
  margin-bottom: 0.5rem;
}
.step-title {
  font-family: var(--font-display);
  font-weight: 800;
  margin-bottom: 0.4rem;
}
.step-desc {
  color: var(--text-muted);
  font-size: 0.9rem;
}
.guide-teaser .container {
  background: linear-gradient(135deg, #f5fff7, #effcf4);
  border: 1px solid #d8f3df;
  border-radius: 24px;
  padding: clamp(1.5rem, 4vw, 2.5rem);
}
.guide-teaser-title {
  font-family: var(--font-display);
  font-size: clamp(1.4rem, 4vw, 2rem);
  margin-bottom: 0.75rem;
}
.guide-teaser-desc {
  color: var(--text-muted);
  margin-bottom: 1rem;
}
.btn-outline {
  border: 1.5px solid currentColor;
  background: transparent;
}
</style>
